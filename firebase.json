{
  "hosting": {
    "site": "applypilot-career",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".firebaserc.example",
      ".git",
      ".git/**",
      ".firebase",
      ".firebase/**",
      ".gitignore",
      "README.md",
      "*.md",
      "firestore.rules",
      "firestore.indexes.json",
      "firebase-debug.log",
      "**/.*",
      "**/node_modules/**",
      ".vscode",
      ".vscode/**"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=300"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
